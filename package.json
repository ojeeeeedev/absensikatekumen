{
  "name": "absensikatekumen",
  "version": "2.7.2-d",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "build": "for file in app.js middleware.js api/*.js public/*.js apps-script/*.js scripts/*.js test/*.js; do node --check \"$file\"; done",
    "lint": "eslint app.js middleware.js api public scripts test --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:profile-combobox": "node scripts/check-profile-combobox.js",
    "test:scan-history": "node scripts/check-scan-history-ui.js",
    "test:topic-combobox": "node scripts/check-profile-combobox.js",
    "clasp-push-all": "node scripts/clasp-push-all.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "playwright": "^1.60.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
