{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/profile.html",
      "destination": "/profile",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/daftar",
      "destination": "/api/register"
    },
    {
      "source": "/profile",
      "destination": "/public/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/$1"
    }
  ]
}
